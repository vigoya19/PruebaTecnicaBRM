        {
          "name": "Register Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const payload = pm.response.json();",
                  "  if (payload.idToken) { pm.environment.set('idToken', payload.idToken); pm.environment.set('token', payload.idToken); }",
                  "  if (payload.accessToken) { pm.environment.set('accessToken', payload.accessToken); }",
                  "  if (payload.refreshToken) { pm.environment.set('refreshToken', payload.refreshToken); }",
                  "  if (payload.customer && payload.customer.customerId) {",
                  "    pm.environment.set('customerId', payload.customer.customerId);",
                  "    pm.environment.set('targetCustomerId', payload.customer.customerId);",
                  "  }",
                  "  if (payload.customer && payload.customer.email) { pm.environment.set('customerEmail', payload.customer.email); }",
                  "  if (payload.customer && payload.customer.name) { pm.environment.set('customerName', payload.customer.name); }",
                  "  if (payload.customer && payload.customer.phone) { pm.environment.set('customerPhone', payload.customer.phone); }",
                  "  if (payload.customer && payload.customer.notificationPreference) {",
                  "    pm.environment.set('notificationPreference', payload.customer.notificationPreference);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{customerEmail}}\",\n  \"password\": \"{{customerPassword}}\",\n  \"name\": \"{{customerName}}\",\n  \"phone\": \"{{customerPhone}}\",\n  \"notificationPreference\": \"{{notificationPreference}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            }
